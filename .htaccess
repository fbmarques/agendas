# Fallback quando o Document Root está no diretório raiz do projeto
# (Hostinger normalmente aponta para public_html; se você não conseguiu apontar
# direto para /public, este arquivo redireciona todo o tráfego para lá).
<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
